# Production — values live on the EC2 server at /var/www/plantathome/api/.env
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:REPLACE_ME

DB_CONNECTION=mysql
DB_HOST=RDS_ENDPOINT
DB_PORT=3306
DB_DATABASE=plantathome
DB_USERNAME=REPLACE_ME
DB_PASSWORD=REPLACE_ME

MEDIA_DISK=s3
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=plantathome-media-prod

RAZORPAY_KEY=rzp_live_REPLACE_ME
RAZORPAY_SECRET=REPLACE_ME

MAIL_MAILER=smtp
MAIL_FROM_ADDRESS=noreply@plantathome.in
