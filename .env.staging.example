# Staging — copy to .env and fill in secrets (Railway env vars override these at runtime)
APP_ENV=staging
APP_DEBUG=false
APP_KEY=base64:REPLACE_ME

DB_CONNECTION=mysql
DB_HOST=RAILWAY_MYSQL_HOST
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=RAILWAY_MYSQL_PASSWORD

MEDIA_DISK=public

RAZORPAY_KEY=rzp_test_REPLACE_ME
RAZORPAY_SECRET=REPLACE_ME

MAIL_MAILER=smtp
MAIL_FROM_ADDRESS=noreply@plantathome.in
